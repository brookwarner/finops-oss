  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@visx/curve": "^3.12.0",
    "@visx/event": "^3.12.0",
    "@visx/gradient": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/tooltip": "^3.12.0",
    "akahu": "^2.5.1",
    "jose": "^6.2.3",
    "mcp-handler": "^1.1.0",
    "next": "15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.15",
    "ts-json-schema-generator": "2.9.0",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  },
  "packageManager": "pnpm@9.12.0"
