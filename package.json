{
  "name": "finops",
  "version": "0.34.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --project-id YOUR_PROJECT_REF > src/lib/supabase/database.types.ts",
