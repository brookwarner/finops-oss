# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Akahu personal app: app token + user token (no OAuth)
AKAHU_APP_TOKEN=
AKAHU_APP_SECRET=
AKAHU_USER_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron
CRON_SECRET=

# Optional: monthly home-value refresh (manual asset tracked via homes.co.nz)
# HOME_PROPERTY_ID=your-homes-co-nz-property-id
# HOME_ACCOUNT_KEY=manual_home_example

# Optional: accounts the cashflow forecast special-cases (your own Akahu account ids)
# FORECAST_CHECKING_ACCOUNT_ID=
# FORECAST_SAVINGS_ACCOUNT_ID=
# FORECAST_REVOLVING_ACCOUNT_ID=

# Anthropic (LLM categorisation fallback)
ANTHROPIC_API_KEY=

# Telegram alerts + conversational write-back (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_WEBHOOK_SECRET=

# MCP (HTTP transport) — public base URL of your deployment
# MCP_PUBLIC_URL=https://finops.example.com
# MCP_JWT_SECRET=
